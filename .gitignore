#############
# Terraform #
#############

# State
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Working directory
**/.terraform/*

# Lock (to keep)
#! .terraform.lock.hcl

########
# SOPS #
########

# Keys
*.agekey
age.key
keys.txt

# Decrypted secret files — never commit these
# Encrypted versions are named *.enc.yaml and are safe to commit
secrets.yaml
*.dec.yaml

#######
# NIX #
#######

# Result symlinks
result
result-*

# direnv
.direnv/

# Local configs
.envrc

